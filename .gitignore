# python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
dist/
build/

# env & credentials — zero-secrets discipline: this repo is PUBLIC.
# Keys live only in the local shell env and per-instance vast.ai env vars.
.env
.env.*
*.key
*.pem
.netrc
netrc
*_api_key*

# data / runs / artifacts (never committed).
# ROOT-ANCHORED on purpose: an unanchored `data/` also ignores src/querent/data/
# — this silently dropped the whole data package from the repo once (found when
# the first cloud clone crashed on import). tests/test_repo_hygiene.py guards this.
/data/
/ckpts/
/outputs/
/wandb/
/artifacts/
/results/
*.ckpt
*.pt

# tooling
.pytest_cache/
.ruff_cache/
.DS_Store
